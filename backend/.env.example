# ═══════════════════════════════════════════════════════════════════════
# Waypoint API — Environment Variables
# Copy this file to `.env` and fill in your values.
# ═══════════════════════════════════════════════════════════════════════

# --- App ---
APP_NAME="Waypoint API"
DEBUG=false
# Comma-separated list of allowed CORS origins
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# --- Supabase ---
# Get these from your Supabase project: Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
# Get this from: Settings → API → JWT Settings → JWT Secret
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# --- Database ---
# Async Postgres URL using asyncpg driver
# Format: postgresql+asyncpg://user:password@host:port/database
# For Supabase: Settings → Database → Connection string (URI) → swap `postgresql://` for `postgresql+asyncpg://`
DATABASE_URL=postgresql+asyncpg://postgres:your-password@db.your-project.supabase.co:5432/postgres

# --- Cognee (Memory System) ---
# API key for Cognee Cloud (leave empty if running Cognee locally)
COGNEE_API_KEY=
# LLM API key that Cognee uses internally for knowledge graph processing
# This is the OpenAI/Anthropic key Cognee uses — separate from ANTHROPIC_API_KEY
COGNEE_LLM_API_KEY=sk-your-openai-key-for-cognee
# LLM provider and model for Cognee's internal processing
COGNEE_LLM_PROVIDER=openai
COGNEE_LLM_MODEL=gpt-4o-mini
# Vector DB backend (lancedb = local/free, pgvector = Supabase, qdrant = hosted)
COGNEE_VECTOR_DB=lancedb

# --- Anthropic (Primary LLM for Orchestrator) ---
# Used for roadmap generation, outreach drafting, resource finding
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key

# --- OpenRouter (BYOK Fallback) ---
# Users can bring their own OpenRouter key for alternative models
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# --- Encryption ---
# 32-byte hex key for AES-256 encryption of BYOK keys via pgcrypto
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
MASTER_KEY=your-64-char-hex-master-key-generate-with-secrets-token-hex-32
